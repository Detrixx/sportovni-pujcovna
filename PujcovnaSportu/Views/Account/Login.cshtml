@{
    ViewData["Title"] = "Přihlášení";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <h2>Přihlášení</h2>

        @if (ViewBag.Chyba != null)
        {
            <div class="alert alert-danger">@ViewBag.Chyba</div>
        }

        <form method="post">
            <div class="mb-3">
                <label>Email</label>
                <input type="email" name="email" class="form-control" required />
            </div>
            <div class="mb-3">
                <label>Heslo</label>
                <input type="password" name="heslo" class="form-control" required />
            </div>
            <button type="submit" class="btn btn-primary w-100">Přihlásit se</button>
        </form>

        <p class="mt-3 text-center">
            Nemáš účet? <a asp-action="Register">Zaregistruj se</a>
        </p>
    </div>
</div>